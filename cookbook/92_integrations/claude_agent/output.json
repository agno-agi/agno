UserMessage(content=[ToolResultBlock(tool_use_id='toolu_01BYzzWNPPiWCn5B1UL5HFhB', content='     1→import asyncio\n     2→import hmac\n     3→from os import getenv\n     4→from typing import Any, List, Optional, Set\n     5→\n     6→from fastapi import Depends, HTTPException, Request\n     7→from fastapi.security import HTTPAuthorizationCredentials, HTTPBearer\n     8→\n     9→from agno.os.scopes import get_accessible_resource_ids, has_required_scopes\n    10→from agno.os.settings import AgnoAPISettings\n    11→\n    12→# Create a global HTTPBearer instance\n    13→security = HTTPBearer(auto_error=False)\n    14→\n    15→# Scopes granted to the internal service token (used by the scheduler executor).\n    16→# Shared constant so auth.py and jwt.py stay in sync.\n    17→INTERNAL_SERVICE_SCOPES: List[str] = [\n    18→    "agents:read",\n    19→    "agents:run",\n    20→    "teams:read",\n    21→    "teams:run",\n    22→    "workflows:read",\n    23→    "workflows:run",\n    24→    "schedules:read",\n    25→    "schedules:write",\n    26→    "schedules:delete",\n    27→]\n    28→\n    29→\n    30→def get_auth_token_from_request(request: Request) -> Optional[str]:\n    31→    """\n    32→    Extract the JWT/Bearer token from the Authorization header.\n    33→\n    34→    This is used to forward the auth token to remote agents/teams/workflows\n    35→    when making requests through the gateway.\n    36→\n    37→    Args:\n    38→        request: The FastAPI request object\n    39→\n    40→    Returns:\n    41→        The bearer token string if present, None otherwise\n    42→\n    43→    Usage:\n    44→        auth_token = get_auth_token_from_request(request)\n    45→        if auth_token and isinstance(agent, RemoteAgent):\n    46→            await agent.arun(message, auth_token=auth_token)\n    47→    """\n    48→    auth_header = request.headers.get("Authorization")\n    49→    if auth_header and auth_header.lower().startswith("bearer "):\n    50→        return auth_header[7:]  # Remove "Bearer " prefix\n    51→    return None\n    52→\n    53→\n    54→def _is_jwt_configured() -> bool:\n    55→    """Check if JWT authentication is configured via environment variables.\n    56→\n    57→    This covers cases where JWT middleware is set up manually (not via authorization=True).\n    58→    """\n    59→    return bool(getenv("JWT_VERIFICATION_KEY") or getenv("JWT_JWKS_FILE"))\n    60→\n    61→\n    62→def get_authentication_dependency(settings: AgnoAPISettings):\n    63→    """\n    64→    Create an authentication dependency function for FastAPI routes.\n    65→\n    66→    This handles security key authentication (OS_SECURITY_KEY).\n    67→    When JWT authorization is enabled (via authorization=True, JWT environment variables,\n    68→    or manually added JWT middleware), this dependency is skipped as JWT middleware\n    69→    handles authentication.\n    70→\n    71→    Args:\n    72→        settings: The API settings containing the security key and authorization flag\n    73→\n    74→    Returns:\n    75→        A dependency function that can be used with FastAPI\'s Depends()\n    76→    """\n    77→\n    78→    async def auth_dependency(request: Request, credentials: HTTPAuthorizationCredentials = Depends(security)) -> bool:\n    79→        # If JWT authorization is enabled via settings (authorization=True on AgentOS)\n    80→        if settings and settings.authorization_enabled:\n    81→            return True\n    82→\n    83→        # Check if JWT middleware has already handled authentication\n    84→        if getattr(request.state, "authenticated", False):\n    85→            return True\n    86→\n    87→        # Also skip if JWT is configured via environment variables\n    88→        if _is_jwt_configured():\n    89→            return True\n    90→\n    91→        # If no security key is set, skip authentication entirely\n    92→        if not settings or not settings.os_security_key:\n    93→            return True\n    94→\n    95→        # If security is enabled but no authorization header provided, fail\n    96→        if not credentials:\n    97→            raise HTTPException(status_code=401, detail="Authorization header required")\n    98→\n    99→        token = credentials.credentials\n   100→\n   101→        # Check internal service token (used by scheduler executor)\n   102→        internal_token = getattr(request.app.state, "internal_service_token", None)\n   103→        if internal_token and hmac.compare_digest(token, internal_token):\n   104→            request.state.authenticated = True\n   105→            request.state.user_id = "__scheduler__"\n   106→            request.state.scopes = list(INTERNAL_SERVICE_SCOPES)\n   107→            return True\n   108→\n   109→        # Verify the token against security key\n   110→        if token != settings.os_security_key:\n   111→            raise HTTPException(status_code=401, detail="Invalid authentication token")\n   112→\n   113→        return True\n   114→\n   115→    return auth_dependency\n   116→\n   117→\n   118→def validate_websocket_token(token: str, settings: AgnoAPISettings) -> bool:\n   119→    """\n   120→    Validate a bearer token for WebSocket authentication (legacy os_security_key method).\n   121→\n   122→    When JWT authorization is enabled (via authorization=True or JWT environment variables),\n   123→    this validation is skipped as JWT middleware handles authentication.\n   124→\n   125→    Args:\n   126→        token: The bearer token to validate\n   127→        settings: The API settings containing the security key and authorization flag\n   128→\n   129→    Returns:\n   130→        True if the token is valid or authentication is disabled, False otherwise\n   131→    """\n   132→    # If JWT authorization is enabled, skip security key validation\n   133→    if settings and settings.authorization_enabled:\n   134→        return True\n   135→\n   136→    # Also skip if JWT is configured via environment variables (manual JWT middleware setup)\n   137→    if _is_jwt_configured():\n   138→        return True\n   139→\n   140→    # If no security key is set, skip authentication entirely\n   141→    if not settings or not settings.os_security_key:\n   142→        return True\n   143→\n   144→    # Verify the token matches the configured security key\n   145→    return token == settings.os_security_key\n   146→\n   147→\n   148→def get_accessible_resources(request: Request, resource_type: str) -> Set[str]:\n   149→    """\n   150→    Get the set of resource IDs the user has access to based on their scopes.\n   151→\n   152→    This function is used to filter lists of resources (agents, teams, workflows)\n   153→    based on the user\'s scopes from their JWT token.\n   154→\n   155→    Args:\n   156→        request: The FastAPI request object (contains request.state.scopes)\n   157→        resource_type: Type of resource ("agents", "teams", "workflows")\n   158→\n   159→    Returns:\n   160→        Set of resource IDs the user can access. Returns {"*"} for wildcard access.\n   161→\n   162→    Usage:\n   163→        accessible_ids = get_accessible_resources(request, "agents")\n   164→        if "*" not in accessible_ids:\n   165→            agents = [a for a in agents if a.id in accessible_ids]\n   166→\n   167→    Examples:\n   168→        >>> # User with specific agent access\n   169→        >>> # Token scopes: ["agent-os:my-os:agents:my-agent:read"]\n   170→        >>> get_accessible_resources(request, "agents")\n   171→        {\'my-agent\'}\n   172→\n   173→        >>> # User with wildcard access\n   174→        >>> # Token scopes: ["agent-os:my-os:agents:*:read"] or ["admin"]\n   175→        >>> get_accessible_resources(request, "agents")\n   176→        {\'*\'}\n   177→\n   178→        >>> # User with agent-os level access (global resource scope)\n   179→        >>> # Token scopes: ["agent-os:my-os:agents:read"]\n   180→        >>> get_accessible_resources(request, "agents")\n   181→        {\'*\'}\n   182→    """\n   183→    # Check if accessible_resource_ids is already cached in request state (set by JWT middleware)\n   184→    # This happens when user doesn\'t have global scope but has specific resource scopes\n   185→    cached_ids = getattr(request.state, "accessible_resource_ids", None)\n   186→    if cached_ids is not None:\n   187→        return cached_ids\n   188→\n   189→    # Get user\'s scopes from request state (set by JWT middleware)\n   190→    user_scopes = getattr(request.state, "scopes", [])\n   191→\n   192→    # Get accessible resource IDs\n   193→    accessible_ids = get_accessible_resource_ids(user_scopes=user_scopes, resource_type=resource_type)\n   194→\n   195→    return accessible_ids\n   196→\n   197→\n   198→def filter_resources_by_access(request: Request, resources: List, resource_type: str) -> List:\n   199→    """\n   200→    Filter a list of resources based on user\'s access permissions.\n   201→\n   202→    Args:\n   203→        request: The FastAPI request object\n   204→        resources: List of resource objects (agents, teams, or workflows) with \'id\' attribute\n   205→        resource_type: Type of resource ("agents", "teams", "workflows")\n   206→\n   207→    Returns:\n   208→        Filtered list of resources the user has access to\n   209→\n   210→    Usage:\n   211→        agents = filter_resources_by_access(request, all_agents, "agents")\n   212→        teams = filter_resources_by_access(request, all_teams, "teams")\n   213→        workflows = filter_resources_by_access(request, all_workflows, "workflows")\n   214→\n   215→    Examples:\n   216→        >>> # User with specific access\n   217→        >>> agents = [Agent(id="agent-1"), Agent(id="agent-2"), Agent(id="agent-3")]\n   218→        >>> # Token scopes: ["agent-os:my-os:agents:agent-1:read", "agent-os:my-os:agents:agent-2:read"]\n   219→        >>> filter_resources_by_access(request, agents, "agents")\n   220→        [Agent(id="agent-1"), Agent(id="agent-2")]\n   221→\n   222→        >>> # User with wildcard access\n   223→        >>> # Token scopes: ["admin"]\n   224→        >>> filter_resources_by_access(request, agents, "agents")\n   225→        [Agent(id="agent-1"), Agent(id="agent-2"), Agent(id="agent-3")]\n   226→    """\n   227→    accessible_ids = get_accessible_resources(request, resource_type)\n   228→\n   229→    # Wildcard access - return all resources\n   230→    if "*" in accessible_ids:\n   231→        return resources\n   232→\n   233→    # Filter to only accessible resources\n   234→    return [r for r in resources if r.id in accessible_ids]\n   235→\n   236→\n   237→def check_resource_access(request: Request, resource_id: str, resource_type: str, action: str = "read") -> bool:\n   238→    """\n   239→    Check if user has access to a specific resource.\n   240→\n   241→    Args:\n   242→        request: The FastAPI request object\n   243→        resource_id: ID of the resource to check\n   244→        resource_type: Type of resource ("agents", "teams", "workflows")\n   245→        action: Action to check ("read", "run", etc.)\n   246→\n   247→    Returns:\n   248→        True if user has access, False otherwise\n   249→\n   250→    Usage:\n   251→        if not check_resource_access(request, agent_id, "agents", "run"):\n   252→            raise HTTPException(status_code=403, detail="Access denied")\n   253→\n   254→    Examples:\n   255→        >>> # Token scopes: ["agent-os:my-os:agents:my-agent:read", "agent-os:my-os:agents:my-agent:run"]\n   256→        >>> check_resource_access(request, "my-agent", "agents", "run")\n   257→        True\n   258→\n   259→        >>> check_resource_access(request, "other-agent", "agents", "run")\n   260→        False\n   261→    """\n   262→    accessible_ids = get_accessible_resources(request, resource_type)\n   263→\n   264→    # Wildcard access grants all permissions\n   265→    if "*" in accessible_ids:\n   266→        return True\n   267→\n   268→    # Check if user has access to this specific resource\n   269→    return resource_id in accessible_ids\n   270→\n   271→\n   272→def require_resource_access(resource_type: str, action: str, resource_id_param: str):\n   273→    """\n   274→    Create a dependency that checks if the user has access to a specific resource.\n   275→\n   276→    This dependency factory creates a FastAPI dependency that automatically checks\n   277→    authorization when authorization is enabled. It extracts the resource ID from\n   278→    the path parameters and verifies the user has the required access.\n   279→\n   280→    Args:\n   281→        resource_type: Type of resource ("agents", "teams", "workflows")\n   282→        action: Action to check ("read", "run")\n   283→        resource_id_param: Name of the path parameter containing the resource ID\n   284→\n   285→    Returns:\n   286→        A dependency function for use with FastAPI\'s Depends()\n   287→\n   288→    Usage:\n   289→        @router.post("/agents/{agent_id}/runs")\n   290→        async def create_agent_run(\n   291→            agent_id: str,\n   292→            request: Request,\n   293→            _: None = Depends(require_resource_access("agents", "run", "agent_id")),\n   294→        ):\n   295→            ...\n   296→\n   297→        @router.get("/agents/{agent_id}")\n   298→        async def get_agent(\n   299→            agent_id: str,\n   300→            request: Request,\n   301→            _: None = Depends(require_resource_access("agents", "read", "agent_id")),\n   302→        ):\n   303→            ...\n   304→\n   305→    Examples:\n   306→        >>> # Creates dependency for checking agent run access\n   307→        >>> dep = require_resource_access("agents", "run", "agent_id")\n   308→\n   309→        >>> # Creates dependency for checking team read access\n   310→        >>> dep = require_resource_access("teams", "read", "team_id")\n   311→    """\n   312→    # Map resource_type to singular form for error messages\n   313→    resource_singular = {\n   314→        "agents": "agent",\n   315→        "teams": "team",\n   316→        "workflows": "workflow",\n   317→    }.get(resource_type, resource_type.rstrip("s"))\n   318→\n   319→    async def dependency(request: Request):\n   320→        # Only check authorization if it\'s enabled\n   321→        if not getattr(request.state, "authorization_enabled", False):\n   322→            return\n   323→\n   324→        # Get the resource_id from path parameters\n   325→        resource_id = request.path_params.get(resource_id_param)\n   326→        if resource_id and not check_resource_access(request, resource_id, resource_type, action):\n   327→            raise HTTPException(status_code=403, detail=f"Access denied to {action} this {resource_singular}")\n   328→\n   329→    return dependency\n   330→\n   331→\n   332→def require_approval_resolved(db: Any) -> Any:\n   333→    """\n   334→    Dependency factory that blocks a run continuation when a pending admin-required\n   335→    approval exists for the run.\n   336→\n   337→    Designed to sit alongside ``require_resource_access`` in the route\'s\n   338→    ``dependencies`` list.  Pass the OS-level DB adapter at router-creation time\n   339→    (the same pattern used by ``get_approval_router``).\n   340→\n   341→    Usage::\n   342→\n   343→        dependencies=[\n   344→            Depends(require_resource_access("agents", "run", "agent_id")),\n   345→            Depends(require_approval_resolved(os.db)),\n   346→        ]\n   347→    """\n   348→\n   349→    async def dependency(request: Request) -> None:\n   350→        # Mirror require_resource_access: skip entirely when authorization is disabled.\n   351→        if not getattr(request.state, "authorization_enabled", False):\n   352→            return\n   353→\n   354→        if db is None:\n   355→            return\n   356→\n   357→        # Callers with approvals:write (admins) bypass this gate — they can\n   358→        # force-continue a run for operational or debugging purposes.\n   359→        user_scopes: List[str] = getattr(request.state, "scopes", [])\n   360→        if has_required_scopes(user_scopes, ["approvals:write"]):\n   361→            return\n   362→\n   363→        run_id: Optional[str] = request.path_params.get("run_id")\n   364→        if not run_id:\n   365→            return\n   366→\n   367→        fn = getattr(db, "get_approvals", None)\n   368→        if fn is None:\n   369→            return\n   370→\n   371→        try:\n   372→            if asyncio.iscoroutinefunction(fn):\n   373→                result = await fn(run_id=run_id, status="pending", approval_type="required")\n   374→            else:\n   375→                result = fn(run_id=run_id, status="pending", approval_type="required")\n   376→\n   377→            approvals = result[0] if isinstance(result, tuple) else result\n   378→            if approvals:\n   379→                raise HTTPException(\n   380→                    status_code=403,\n   381→                    detail="This run requires admin approval before it can be continued",\n   382→                )\n   383→        except HTTPException:\n   384→            raise\n   385→        except Exception as exc:\n   386→            # DB doesn\'t support approvals or another transient error — let the\n   387→            # run continue so non-approval setups are unaffected.\n   388→            from agno.utils.log import log_warning\n   389→\n   390→            log_warning(f"Approval resolution check skipped due to error: {exc}")\n   391→            return\n   392→\n   393→    return dependency\n   394→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n', is_error=None)], uuid='2466b3e4-9d48-4792-874e-ccc3eca9d16b', parent_tool_use_id=None, tool_use_result={'type': 'text', 'file': {'filePath': '/Users/ayushjha/Desktop/lab/agno/libs/agno/agno/os/auth.py', 'content': 'import asyncio\nimport hmac\nfrom os import getenv\nfrom typing import Any, List, Optional, Set\n\nfrom fastapi import Depends, HTTPException, Request\nfrom fastapi.security import HTTPAuthorizationCredentials, HTTPBearer\n\nfrom agno.os.scopes import get_accessible_resource_ids, has_required_scopes\nfrom agno.os.settings import AgnoAPISettings\n\n# Create a global HTTPBearer instance\nsecurity = HTTPBearer(auto_error=False)\n\n# Scopes granted to the internal service token (used by the scheduler executor).\n# Shared constant so auth.py and jwt.py stay in sync.\nINTERNAL_SERVICE_SCOPES: List[str] = [\n    "agents:read",\n    "agents:run",\n    "teams:read",\n    "teams:run",\n    "workflows:read",\n    "workflows:run",\n    "schedules:read",\n    "schedules:write",\n    "schedules:delete",\n]\n\n\ndef get_auth_token_from_request(request: Request) -> Optional[str]:\n    """\n    Extract the JWT/Bearer token from the Authorization header.\n\n    This is used to forward the auth token to remote agents/teams/workflows\n    when making requests through the gateway.\n\n    Args:\n        request: The FastAPI request object\n\n    Returns:\n        The bearer token string if present, None otherwise\n\n    Usage:\n        auth_token = get_auth_token_from_request(request)\n        if auth_token and isinstance(agent, RemoteAgent):\n            await agent.arun(message, auth_token=auth_token)\n    """\n    auth_header = request.headers.get("Authorization")\n    if auth_header and auth_header.lower().startswith("bearer "):\n        return auth_header[7:]  # Remove "Bearer " prefix\n    return None\n\n\ndef _is_jwt_configured() -> bool:\n    """Check if JWT authentication is configured via environment variables.\n\n    This covers cases where JWT middleware is set up manually (not via authorization=True).\n    """\n    return bool(getenv("JWT_VERIFICATION_KEY") or getenv("JWT_JWKS_FILE"))\n\n\ndef get_authentication_dependency(settings: AgnoAPISettings):\n    """\n    Create an authentication dependency function for FastAPI routes.\n\n    This handles security key authentication (OS_SECURITY_KEY).\n    When JWT authorization is enabled (via authorization=True, JWT environment variables,\n    or manually added JWT middleware), this dependency is skipped as JWT middleware\n    handles authentication.\n\n    Args:\n        settings: The API settings containing the security key and authorization flag\n\n    Returns:\n        A dependency function that can be used with FastAPI\'s Depends()\n    """\n\n    async def auth_dependency(request: Request, credentials: HTTPAuthorizationCredentials = Depends(security)) -> bool:\n        # If JWT authorization is enabled via settings (authorization=True on AgentOS)\n        if settings and settings.authorization_enabled:\n            return True\n\n        # Check if JWT middleware has already handled authentication\n        if getattr(request.state, "authenticated", False):\n            return True\n\n        # Also skip if JWT is configured via environment variables\n        if _is_jwt_configured():\n            return True\n\n        # If no security key is set, skip authentication entirely\n        if not settings or not settings.os_security_key:\n            return True\n\n        # If security is enabled but no authorization header provided, fail\n        if not credentials:\n            raise HTTPException(status_code=401, detail="Authorization header required")\n\n        token = credentials.credentials\n\n        # Check internal service token (used by scheduler executor)\n        internal_token = getattr(request.app.state, "internal_service_token", None)\n        if internal_token and hmac.compare_digest(token, internal_token):\n            request.state.authenticated = True\n            request.state.user_id = "__scheduler__"\n            request.state.scopes = list(INTERNAL_SERVICE_SCOPES)\n            return True\n\n        # Verify the token against security key\n        if token != settings.os_security_key:\n            raise HTTPException(status_code=401, detail="Invalid authentication token")\n\n        return True\n\n    return auth_dependency\n\n\ndef validate_websocket_token(token: str, settings: AgnoAPISettings) -> bool:\n    """\n    Validate a bearer token for WebSocket authentication (legacy os_security_key method).\n\n    When JWT authorization is enabled (via authorization=True or JWT environment variables),\n    this validation is skipped as JWT middleware handles authentication.\n\n    Args:\n        token: The bearer token to validate\n        settings: The API settings containing the security key and authorization flag\n\n    Returns:\n        True if the token is valid or authentication is disabled, False otherwise\n    """\n    # If JWT authorization is enabled, skip security key validation\n    if settings and settings.authorization_enabled:\n        return True\n\n    # Also skip if JWT is configured via environment variables (manual JWT middleware setup)\n    if _is_jwt_configured():\n        return True\n\n    # If no security key is set, skip authentication entirely\n    if not settings or not settings.os_security_key:\n        return True\n\n    # Verify the token matches the configured security key\n    return token == settings.os_security_key\n\n\ndef get_accessible_resources(request: Request, resource_type: str) -> Set[str]:\n    """\n    Get the set of resource IDs the user has access to based on their scopes.\n\n    This function is used to filter lists of resources (agents, teams, workflows)\n    based on the user\'s scopes from their JWT token.\n\n    Args:\n        request: The FastAPI request object (contains request.state.scopes)\n        resource_type: Type of resource ("agents", "teams", "workflows")\n\n    Returns:\n        Set of resource IDs the user can access. Returns {"*"} for wildcard access.\n\n    Usage:\n        accessible_ids = get_accessible_resources(request, "agents")\n        if "*" not in accessible_ids:\n            agents = [a for a in agents if a.id in accessible_ids]\n\n    Examples:\n        >>> # User with specific agent access\n        >>> # Token scopes: ["agent-os:my-os:agents:my-agent:read"]\n        >>> get_accessible_resources(request, "agents")\n        {\'my-agent\'}\n\n        >>> # User with wildcard access\n        >>> # Token scopes: ["agent-os:my-os:agents:*:read"] or ["admin"]\n        >>> get_accessible_resources(request, "agents")\n        {\'*\'}\n\n        >>> # User with agent-os level access (global resource scope)\n        >>> # Token scopes: ["agent-os:my-os:agents:read"]\n        >>> get_accessible_resources(request, "agents")\n        {\'*\'}\n    """\n    # Check if accessible_resource_ids is already cached in request state (set by JWT middleware)\n    # This happens when user doesn\'t have global scope but has specific resource scopes\n    cached_ids = getattr(request.state, "accessible_resource_ids", None)\n    if cached_ids is not None:\n        return cached_ids\n\n    # Get user\'s scopes from request state (set by JWT middleware)\n    user_scopes = getattr(request.state, "scopes", [])\n\n    # Get accessible resource IDs\n    accessible_ids = get_accessible_resource_ids(user_scopes=user_scopes, resource_type=resource_type)\n\n    return accessible_ids\n\n\ndef filter_resources_by_access(request: Request, resources: List, resource_type: str) -> List:\n    """\n    Filter a list of resources based on user\'s access permissions.\n\n    Args:\n        request: The FastAPI request object\n        resources: List of resource objects (agents, teams, or workflows) with \'id\' attribute\n        resource_type: Type of resource ("agents", "teams", "workflows")\n\n    Returns:\n        Filtered list of resources the user has access to\n\n    Usage:\n        agents = filter_resources_by_access(request, all_agents, "agents")\n        teams = filter_resources_by_access(request, all_teams, "teams")\n        workflows = filter_resources_by_access(request, all_workflows, "workflows")\n\n    Examples:\n        >>> # User with specific access\n        >>> agents = [Agent(id="agent-1"), Agent(id="agent-2"), Agent(id="agent-3")]\n        >>> # Token scopes: ["agent-os:my-os:agents:agent-1:read", "agent-os:my-os:agents:agent-2:read"]\n        >>> filter_resources_by_access(request, agents, "agents")\n        [Agent(id="agent-1"), Agent(id="agent-2")]\n\n        >>> # User with wildcard access\n        >>> # Token scopes: ["admin"]\n        >>> filter_resources_by_access(request, agents, "agents")\n        [Agent(id="agent-1"), Agent(id="agent-2"), Agent(id="agent-3")]\n    """\n    accessible_ids = get_accessible_resources(request, resource_type)\n\n    # Wildcard access - return all resources\n    if "*" in accessible_ids:\n        return resources\n\n    # Filter to only accessible resources\n    return [r for r in resources if r.id in accessible_ids]\n\n\ndef check_resource_access(request: Request, resource_id: str, resource_type: str, action: str = "read") -> bool:\n    """\n    Check if user has access to a specific resource.\n\n    Args:\n        request: The FastAPI request object\n        resource_id: ID of the resource to check\n        resource_type: Type of resource ("agents", "teams", "workflows")\n        action: Action to check ("read", "run", etc.)\n\n    Returns:\n        True if user has access, False otherwise\n\n    Usage:\n        if not check_resource_access(request, agent_id, "agents", "run"):\n            raise HTTPException(status_code=403, detail="Access denied")\n\n    Examples:\n        >>> # Token scopes: ["agent-os:my-os:agents:my-agent:read", "agent-os:my-os:agents:my-agent:run"]\n        >>> check_resource_access(request, "my-agent", "agents", "run")\n        True\n\n        >>> check_resource_access(request, "other-agent", "agents", "run")\n        False\n    """\n    accessible_ids = get_accessible_resources(request, resource_type)\n\n    # Wildcard access grants all permissions\n    if "*" in accessible_ids:\n        return True\n\n    # Check if user has access to this specific resource\n    return resource_id in accessible_ids\n\n\ndef require_resource_access(resource_type: str, action: str, resource_id_param: str):\n    """\n    Create a dependency that checks if the user has access to a specific resource.\n\n    This dependency factory creates a FastAPI dependency that automatically checks\n    authorization when authorization is enabled. It extracts the resource ID from\n    the path parameters and verifies the user has the required access.\n\n    Args:\n        resource_type: Type of resource ("agents", "teams", "workflows")\n        action: Action to check ("read", "run")\n        resource_id_param: Name of the path parameter containing the resource ID\n\n    Returns:\n        A dependency function for use with FastAPI\'s Depends()\n\n    Usage:\n        @router.post("/agents/{agent_id}/runs")\n        async def create_agent_run(\n            agent_id: str,\n            request: Request,\n            _: None = Depends(require_resource_access("agents", "run", "agent_id")),\n        ):\n            ...\n\n        @router.get("/agents/{agent_id}")\n        async def get_agent(\n            agent_id: str,\n            request: Request,\n            _: None = Depends(require_resource_access("agents", "read", "agent_id")),\n        ):\n            ...\n\n    Examples:\n        >>> # Creates dependency for checking agent run access\n        >>> dep = require_resource_access("agents", "run", "agent_id")\n\n        >>> # Creates dependency for checking team read access\n        >>> dep = require_resource_access("teams", "read", "team_id")\n    """\n    # Map resource_type to singular form for error messages\n    resource_singular = {\n        "agents": "agent",\n        "teams": "team",\n        "workflows": "workflow",\n    }.get(resource_type, resource_type.rstrip("s"))\n\n    async def dependency(request: Request):\n        # Only check authorization if it\'s enabled\n        if not getattr(request.state, "authorization_enabled", False):\n            return\n\n        # Get the resource_id from path parameters\n        resource_id = request.path_params.get(resource_id_param)\n        if resource_id and not check_resource_access(request, resource_id, resource_type, action):\n            raise HTTPException(status_code=403, detail=f"Access denied to {action} this {resource_singular}")\n\n    return dependency\n\n\ndef require_approval_resolved(db: Any) -> Any:\n    """\n    Dependency factory that blocks a run continuation when a pending admin-required\n    approval exists for the run.\n\n    Designed to sit alongside ``require_resource_access`` in the route\'s\n    ``dependencies`` list.  Pass the OS-level DB adapter at router-creation time\n    (the same pattern used by ``get_approval_router``).\n\n    Usage::\n\n        dependencies=[\n            Depends(require_resource_access("agents", "run", "agent_id")),\n            Depends(require_approval_resolved(os.db)),\n        ]\n    """\n\n    async def dependency(request: Request) -> None:\n        # Mirror require_resource_access: skip entirely when authorization is disabled.\n        if not getattr(request.state, "authorization_enabled", False):\n            return\n\n        if db is None:\n            return\n\n        # Callers with approvals:write (admins) bypass this gate — they can\n        # force-continue a run for operational or debugging purposes.\n        user_scopes: List[str] = getattr(request.state, "scopes", [])\n        if has_required_scopes(user_scopes, ["approvals:write"]):\n            return\n\n        run_id: Optional[str] = request.path_params.get("run_id")\n        if not run_id:\n            return\n\n        fn = getattr(db, "get_approvals", None)\n        if fn is None:\n            return\n\n        try:\n            if asyncio.iscoroutinefunction(fn):\n                result = await fn(run_id=run_id, status="pending", approval_type="required")\n            else:\n                result = fn(run_id=run_id, status="pending", approval_type="required")\n\n            approvals = result[0] if isinstance(result, tuple) else result\n            if approvals:\n                raise HTTPException(\n                    status_code=403,\n                    detail="This run requires admin approval before it can be continued",\n                )\n        except HTTPException:\n            raise\n        except Exception as exc:\n            # DB doesn\'t support approvals or another transient error — let the\n            # run continue so non-approval setups are unaffected.\n            from agno.utils.log import log_warning\n\n            log_warning(f"Approval resolution check skipped due to error: {exc}")\n            return\n\n    return dependency\n', 'numLines': 394, 'startLine': 1, 'totalLines': 394}})
AssistantMessage(content=[ThinkingBlock(thinking="Let me analyze the code carefully to find the bug.\n\nLooking at the code:\n\n1. `get_auth_token_from_request` - Looks fine. Extracts bearer token from Authorization header.\n\n2. `_is_jwt_configured` - Looks fine.\n\n3. `get_authentication_dependency` - Let me look carefully...\n   - Line 110: `if token != settings.os_security_key:` - This uses regular string comparison instead of `hmac.compare_digest()` for the security key comparison. This is a timing attack vulnerability! The internal service token uses `hmac.compare_digest` (line 103) but the security key comparison doesn't. This is a security bug - it should use `hmac.compare_digest(token, settings.os_security_key)`.\n   \n4. `validate_websocket_token` has the same timing attack issue on line 145 where it compares the token directly instead of using constant-time comparison.\n\n5. `check_resource_access` receives an `action` parameter but never actually uses it - it only checks if the resource ID is in the accessible set without verifying the specific action permission, which means the action validation is completely bypassed.\n\n6. Looking at `get_accessible_resources` -\n\nThe caching mechanism could be problematic since it stores `accessible_resource_ids` in request state without filtering by resource type, so if the function is called for different resource types in sequence, it might return cached results from the wrong type. Though this might be intentional if the middleware only calls it once per request.\n\nThe clearest security issues are the timing attacks on lines 110 and 145 where regular string comparison is used instead of `hmac.compare_digest`, and the unused `action` parameter in `check_resource_access` that means action-level permissions aren't actually being validated. I've identified the two timing attack vulnerabilities where plain string comparison is used instead of constant-time comparison, and I'll fix those now.", signature='')], model=